# Frontend (ng serve --port 83 ou tunnel)
E2E_BASE_URL=http://localhost:83

# Backend direto (cleanup/seed API — não passa pelo proxy Angular)
E2E_API_URL=http://localhost:3002/api

# Credenciais admin (2FA desabilitado)
E2E_ADMIN_EMAIL=admin@admin.com
E2E_ADMIN_PASSWORD=

# Demo: delay entre ações (ms)
E2E_SLOW_MO_MS=300

# Ambiente remoto (gravação contra staging)
# E2E_BASE_URL=https://dev-application.lightburden.net
# E2E_API_URL=https://dev-application.lightburden.net/api
